{
    "version": 2,
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/index.py"
        },
        {
            "source": "/admin(.*)",
            "destination": "/api/index.py"
        },
        {
            "source": "/register(.*)",
            "destination": "/api/index.py"
        },
        {
            "source": "/assets/(.*)",
            "destination": "/frontend/assets/$1"
        },
        {
            "source": "/(.*)\\.(js|css|png|jpg|jpeg|svg|ico|gif)",
            "destination": "/frontend/$1.$2"
        },
        {
            "source": "/",
            "destination": "/frontend/index.html"
        },
        {
            "source": "/(.*)",
            "destination": "/frontend/$1.html"
        }
    ]
}